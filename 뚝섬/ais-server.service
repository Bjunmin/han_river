[Unit]
Description=AIS Server
After=network.target

[Service]
Type=simple
# 아래 두 줄을 실제 환경에 맞게 수정
# whoami 로 유저명 확인, pwd 로 프로젝트 경로 확인
User=YOUR_USERNAME
WorkingDirectory=/path/to/ais_server

# nvm 사용 시: `which node` 로 실제 경로 확인 후 아래에 입력
# 예: /home/pi/.nvm/versions/node/v20.0.0/bin/node
ExecStart=/usr/bin/node dist/main.js

# 서버 죽으면 자동 재시작
Restart=always
RestartSec=3

# 로그는 journalctl -u ais-server -f 로 확인
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
